## Copy this file to keystore.properties (same folder) and fill in the real
## values once you've generated a release keystore -- see the "Creating your
## release keystore" instructions from Claude for how to generate the .jks
## file itself. keystore.properties is gitignored; this .example file is not,
## so the required shape is always visible in the repo without ever risking
## a real password getting committed.

storeFile=release.jks
storePassword=CHANGE_ME
keyAlias=tcgmanager
keyPassword=CHANGE_ME
